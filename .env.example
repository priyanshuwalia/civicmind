# CivicMind production defaults are intentionally self-contained for Vercel.
# You can deploy with no environment variables and the app will run with the
# built-in full-stack API, seeded incident data, local portal login, simulated
# AI agents, and in-memory storage.

# Optional: enable real Gemini calls. Leave disabled for hackathon reliability.
ENABLE_GEMINI="false"
GEMINI_API_KEY=""

# Optional: enable Postgres/Prisma persistence. Leave disabled unless your
# database is migrated and reachable from Vercel.
USE_DATABASE="false"
DATABASE_URL=""

# Optional: public app URL for docs/callback references.
APP_URL="https://your-vercel-project.vercel.app"

# Optional: only set this if the frontend is hosted separately from the backend.
# For a normal same-project Vercel deployment, keep it empty.
VITE_API_URL=""
