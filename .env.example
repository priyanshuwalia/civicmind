# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# FIREBASE SERVICE ACCOUNT: JSON string of the service account credentials file
# Format: {"type": "service_account", "project_id": "...", ...}
FIREBASE_SERVICE_ACCOUNT=""

# FIREBASE STORAGE BUCKET: Name of the Firebase Storage Bucket
FIREBASE_STORAGE_BUCKET="your-project-id.appspot.com"

# FIREBASE CLIENT WEB CONFIGURATION (Vite prefix required for frontend access)
VITE_FIREBASE_API_KEY="your-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project-id.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-messaging-sender-id"
VITE_FIREBASE_APP_ID="your-app-id"
