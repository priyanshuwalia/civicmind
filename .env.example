# Required by Prisma/PostgreSQL in production. Use your pooled Neon/Supabase/Vercel
# Postgres connection string when deploying serverless functions.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# Required for Gemini AI API calls. If omitted, the backend falls back to
# simulated agent output.
GEMINI_API_KEY="your_gemini_api_key_here"

# Public URL of the deployed Vercel app.
APP_URL="https://your-vercel-project.vercel.app"

# Leave empty for the normal same-domain Vercel deployment. Only set this if
# the frontend is hosted separately from the backend API.
VITE_API_URL=""

# Firebase Admin service account JSON as a single-line string.
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"your-project-id","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"...","universe_domain":"googleapis.com"}'

# Firebase Storage bucket used by backend uploads.
FIREBASE_STORAGE_BUCKET="your-project-id.appspot.com"

# Firebase client web configuration. Vite exposes only VITE_* values to the
# browser bundle, so these must be present at build time on Vercel.
VITE_FIREBASE_API_KEY="your-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project-id.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-messaging-sender-id"
VITE_FIREBASE_APP_ID="your-app-id"
