{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "functions": {
    "api/[...path].ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/|assets/|favicon.ico|uploads|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
